# Server
NODE_ENV=development
PORT=3900

# Database
DATABASE_URL="postgresql://travelo:travelo_dev@localhost:5433/travelo"

# JWT
JWT_SECRET=change-this-to-a-very-long-random-secret-in-production
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGINS=http://localhost:3901

# Super Admin Seed
SUPER_ADMIN_EMAIL=admin@travelo.com
SUPER_ADMIN_PASSWORD=Admin@123

# Cloudflare R2 (optional for development)
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=travelo-dev
R2_PUBLIC_URL=http://localhost:9000/travelo-dev
