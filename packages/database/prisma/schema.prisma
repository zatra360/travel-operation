  employee   Employee  @relation(fields: [employeeId], references: [id])
  approvedBy User?     @relation("IncentiveApprover", fields: [approvedById], references: [id])
  createdBy   User?    @relation("IncentiveCreator", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
}

// ─── Projects & Tasks ─────────────────────────────────────────

model Project {
  id            String   @id @default(cuid())
  tenantId      String
  branchId      String?
  projectNumber String
  name          String
  description   String?
  status        String   @default("PLANNING")
  priority      String   @default("MEDIUM")
  startDate     DateTime?
  endDate       DateTime?
  clientId      String?
  assignedToId  String?
  budget        Decimal  @db.Decimal(19, 4) @default(0)
  actualCost    Decimal  @db.Decimal(19, 4) @default(0)
  currencyCode  String   @default("USD")
  notes         String?
  metadata      Json?    @default("{}")
  createdById   String?
  updatedById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch?          @relation(fields: [branchId], references: [id])
  client     Client?          @relation("ProjectClient", fields: [clientId], references: [id])
  assignedTo User?            @relation("ProjectManager", fields: [assignedToId], references: [id])
  members    ProjectMember[]
  tasks      Task[]
  timeLogs   ProjectTimeLog[]

  @@unique([tenantId, projectNumber])
  @@index([tenantId])
  @@index([branchId])
  @@index([status])
}

model ProjectMember {
  id         String   @id @default(cuid())
  tenantId   String
  projectId  String
  userId     String
  role       String   @default("MEMBER")
  hourlyRate Decimal? @db.Decimal(19, 4)
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([tenantId])
  @@index([projectId])
}

model Task {
  id             String   @id @default(cuid())
  tenantId       String
  branchId       String?
  projectId      String
  parentTaskId   String?
  title          String
  description    String?
  status         String   @default("TODO")
  priority       String   @default("MEDIUM")
  kanbanOrder    Float    @default(0)
  isMilestone    Boolean  @default(false)
  estimatedHours Float?
  actualHours    Float?
  startDate      DateTime?
  dueDate        DateTime?
  assignedToId   String?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentTask Task?          @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks   Task[]         @relation("SubTasks")
  assignedTo User?          @relation("TaskAssignee", fields: [assignedToId], references: [id])
  checklists TaskChecklist[]
  timeLogs   ProjectTimeLog[]
  dependencies    TaskDependency[] @relation("TaskDependencies")
  dependedOnBy    TaskDependency[] @relation("DependsOnTask")

  @@index([tenantId])
  @@index([projectId])
  @@index([status])
  @@index([assignedToId])
}

model TaskChecklist {
  id            String    @id @default(cuid())
  tenantId      String
  taskId        String
  title         String
  isCompleted   Boolean   @default(false)
  completedById String?
  completedAt   DateTime?
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())

  task        Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completedBy User?  @relation("ChecklistCompleter", fields: [completedById], references: [id])

  @@index([tenantId])
  @@index([taskId])
}

model TaskDependency {
  id              String   @id @default(cuid())
  tenantId        String
  taskId          String
  dependsOnTaskId String
  createdAt       DateTime @default(now())

  task      Task  @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task  @relation("DependsOnTask", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
  @@index([tenantId])
  @@index([taskId])
  @@index([dependsOnTaskId])
}

model ProjectTimeLog {
  id          String   @id @default(cuid())
  tenantId    String
  projectId   String
  taskId      String?
  userId      String
  description String?
  startTime   DateTime?
  endTime     DateTime?
  duration    Int      @default(0)
  billable    Boolean  @default(true)
  hourlyRate  Decimal? @db.Decimal(19, 4)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?   @relation(fields: [taskId], references: [id])
  user    User    @relation("TimeLogUser", fields: [userId], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([taskId])
  @@index([userId])
}

// ─── Master Data System ───────────────────────────────────────

model MasterDataCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  module      String?
  scope       String   @default("GLOBAL")
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  items MasterDataItem[]

  @@index([module])
  @@index([isActive])
}

model MasterDataItem {
  id          String   @id @default(cuid())
  categoryId  String
  code        String
  name        String
  displayName String?
  description String?
  color       String?
  icon        String?
  sortOrder   Int      @default(0)
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  category        MasterDataCategory         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenantOverrides TenantMasterDataOverride[]

  @@unique([categoryId, code])
  @@index([categoryId])
  @@index([isActive])
}

model TenantMasterDataOverride {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  masterItemId String?
  categoryCode String
  code        String
  name        String
  displayName String?
  description String?
  color       String?
  icon        String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  isHidden    Boolean  @default(false)
  isCustom    Boolean  @default(false)
  metadata    Json?    @default("{}")
  createdById  String?
  updatedById  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch?           @relation(fields: [branchId], references: [id])
  masterItem MasterDataItem?   @relation(fields: [masterItemId], references: [id], onDelete: SetNull)

  @@unique([tenantId, branchId, categoryCode, code])
  @@index([tenantId])
  @@index([tenantId, categoryCode])
  @@index([masterItemId])
}

