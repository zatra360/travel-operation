// ─── After-Sales ──────────────────────────────────────────────

model RefundRequest {
  id              String   @id @default(cuid())
  tenantId        String
  branchId        String?
  bookingId       String?
  ticketId        String?
  invoiceId       String?
  clientId        String?
  refundNumber    String
  requestedAmount Decimal @db.Decimal(19, 4)  @default(0)
  approvedAmount  Decimal? @db.Decimal(19, 4)
  status          String   @default("REQUESTED")
  reason          String?
  notes           String?
  requestedById   String?
  approvedById    String?
  processedById   String?
  requestedAt     DateTime @default(now())
  approvedAt      DateTime?
  processedAt     DateTime?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch      Branch?  @relation(fields: [branchId], references: [id])
  booking     Booking? @relation(fields: [bookingId], references: [id])
  ticket      Ticket?  @relation(fields: [ticketId], references: [id])
  invoice     Invoice? @relation(fields: [invoiceId], references: [id])
  client      Client?  @relation("RefundClient", fields: [clientId], references: [id])
  requestedBy User?    @relation("RefundRequester", fields: [requestedById], references: [id])
  approvedBy  User?    @relation("RefundApprover", fields: [approvedById], references: [id])
  processedBy User?    @relation("RefundProcessor", fields: [processedById], references: [id])
  createdBy   User?    @relation("RefundCreator", fields: [createdById], references: [id])

  @@unique([tenantId, refundNumber])
  @@index([tenantId])
  @@index([bookingId])
  @@index([ticketId])
  @@index([status])
}

model ReissueRequest {
  id              String   @id @default(cuid())
  tenantId        String
  branchId        String?
  bookingId       String?
  oldTicketId     String?
  newTicketId     String?
  clientId        String?
  reissueNumber   String
  fareDifference  Decimal @db.Decimal(19, 4)  @default(0)
  serviceCharge   Decimal @db.Decimal(19, 4)  @default(0)
  totalCharge     Decimal @db.Decimal(19, 4)  @default(0)
  status          String   @default("REQUESTED")
  reason          String?
  notes           String?
  requestedById   String?
  approvedById    String?
  processedById   String?
  requestedAt     DateTime @default(now())
  approvedAt      DateTime?
  processedAt     DateTime?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch      Branch?  @relation(fields: [branchId], references: [id])
  booking     Booking? @relation(fields: [bookingId], references: [id])
  oldTicket   Ticket?  @relation("ReissueOldTicket", fields: [oldTicketId], references: [id])
  newTicket   Ticket?  @relation("ReissueNewTicket", fields: [newTicketId], references: [id])
  client      Client?  @relation("ReissueClient", fields: [clientId], references: [id])
  requestedBy User?    @relation("ReissueRequester", fields: [requestedById], references: [id])
  approvedBy  User?    @relation("ReissueApprover", fields: [approvedById], references: [id])
  processedBy User?    @relation("ReissueProcessor", fields: [processedById], references: [id])
  createdBy   User?    @relation("ReissueCreator", fields: [createdById], references: [id])

  @@unique([tenantId, reissueNumber])
  @@index([tenantId])
  @@index([bookingId])
  @@index([status])
}

model CancellationRequest {
  id                String   @id @default(cuid())
  tenantId          String
  branchId          String?
  bookingId         String?
  ticketId          String?
  clientId          String?
  cancellationNumber String
  cancellationCharge Decimal @db.Decimal(19, 4)  @default(0)
  refundableAmount  Decimal @db.Decimal(19, 4)  @default(0)
  status            String   @default("REQUESTED")
  reason            String?
  notes             String?
  requestedById     String?
  approvedById      String?
  processedById     String?
  requestedAt       DateTime @default(now())
  approvedAt        DateTime?
  processedAt       DateTime?
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch      Branch?  @relation(fields: [branchId], references: [id])
  booking     Booking? @relation(fields: [bookingId], references: [id])
  ticket      Ticket?  @relation(fields: [ticketId], references: [id])
  client      Client?  @relation("CancelClient", fields: [clientId], references: [id])
  requestedBy User?    @relation("CancelRequester", fields: [requestedById], references: [id])
  approvedBy  User?    @relation("CancelApprover", fields: [approvedById], references: [id])
  processedBy User?    @relation("CancelProcessor", fields: [processedById], references: [id])
  createdBy   User?    @relation("CancelCreator", fields: [createdById], references: [id])

  @@unique([tenantId, cancellationNumber])
  @@index([tenantId])
  @@index([bookingId])
  @@index([status])
}

// ─── HRM Salary / Commission / Incentive ──────────────────────

model SalaryProfile {
  id           String   @id @default(cuid())
  tenantId     String
  employeeId   String
  baseSalary   Decimal @db.Decimal(19, 4)  @default(0)
  currencyCode String   @default("USD")
  effectiveFrom DateTime
  effectiveTo   DateTime?
  metadata     Json?    @default("{}")
  isActive     Boolean  @default(true)
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])
  createdBy User?   @relation("SalaryProfileCreator", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([employeeId])
}

model SalaryRun {
  id           String   @id @default(cuid())
  tenantId     String
  branchId     String?
  salaryRunNumber String
  period       String
  periodStart  DateTime
  periodEnd    DateTime
  status       String   @default("DRAFT")
  currencyCode String   @default("USD")
  totalGross   Decimal @db.Decimal(19, 4)  @default(0)
  totalDeductions Decimal @db.Decimal(19, 4) @default(0)
  totalNet     Decimal @db.Decimal(19, 4)  @default(0)
  notes        String?
  createdById  String?
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch?       @relation(fields: [branchId], references: [id])
  createdBy User?       @relation("SalaryRunCreator", fields: [createdById], references: [id])
  approvedBy User?      @relation("SalaryRunApprover", fields: [approvedById], references: [id])
  slips   SalarySlip[]

  @@unique([tenantId, salaryRunNumber])
  @@index([tenantId])
  @@index([branchId])
  @@index([status])
}

model SalarySlip {
  id            String   @id @default(cuid())
  tenantId      String
  salaryRunId   String
  employeeId    String
  basePay       Decimal @db.Decimal(19, 4)  @default(0)
  allowances    Decimal @db.Decimal(19, 4)  @default(0)
  commissionEarned Decimal @db.Decimal(19, 4) @default(0)
  incentiveEarned  Decimal @db.Decimal(19, 4) @default(0)
  overtimePay   Decimal @db.Decimal(19, 4)  @default(0)
  grossPay      Decimal @db.Decimal(19, 4)  @default(0)
  deductions    Decimal @db.Decimal(19, 4)  @default(0)
  netPay        Decimal @db.Decimal(19, 4)  @default(0)
  currencyCode  String   @default("USD")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salaryRun  SalaryRun  @relation(fields: [salaryRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@unique([salaryRunId, employeeId])
  @@index([tenantId])
  @@index([employeeId])
}

model Commission {
  id              String   @id @default(cuid())
  tenantId        String
  branchId        String?
  employeeId      String
  sourceType      String
  sourceId        String?
  amount          Decimal @db.Decimal(19, 4)  @default(0)
  currencyCode    String   @default("USD")
  status          String   @default("PENDING")
  calculationBasis String?
  notes           String?
  approvedById    String?
  approvedAt      DateTime?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch?   @relation(fields: [branchId], references: [id])
  employee   Employee  @relation(fields: [employeeId], references: [id])
  approvedBy User?     @relation("CommissionApprover", fields: [approvedById], references: [id])
  createdBy   User?    @relation("CommissionCreator", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([sourceType, sourceId])
  @@index([status])
}

model Incentive {
  id            String   @id @default(cuid())
  tenantId      String
  branchId      String?
  employeeId    String
  incentiveType String
  amount        Decimal @db.Decimal(19, 4)  @default(0)
  currencyCode  String   @default("USD")
  period        String?
  status        String   @default("PENDING")
  reason        String?
  targetId      String?
  approvedById  String?
  approvedAt    DateTime?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch?   @relation(fields: [branchId], references: [id])
  employee   Employee  @relation(fields: [employeeId], references: [id])
  approvedBy User?     @relation("IncentiveApprover", fields: [approvedById], references: [id])
  createdBy   User?    @relation("IncentiveCreator", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
}

// ─── Master Data System ───────────────────────────────────────

model MasterDataCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  module      String?
  scope       String   @default("GLOBAL")
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  items MasterDataItem[]

  @@index([module])
  @@index([isActive])
}

model MasterDataItem {
  id          String   @id @default(cuid())
  categoryId  String
  code        String
  name        String
  displayName String?
  description String?
  color       String?
  icon        String?
  sortOrder   Int      @default(0)
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  category        MasterDataCategory         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenantOverrides TenantMasterDataOverride[]

  @@unique([categoryId, code])
  @@index([categoryId])
  @@index([isActive])
}

model TenantMasterDataOverride {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  masterItemId String?
  categoryCode String
  code        String
  name        String
  displayName String?
  description String?
  color       String?
  icon        String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  isHidden    Boolean  @default(false)
  isCustom    Boolean  @default(false)
  metadata    Json?    @default("{}")
  createdById  String?
  updatedById  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch?           @relation(fields: [branchId], references: [id])
  masterItem MasterDataItem?   @relation(fields: [masterItemId], references: [id], onDelete: SetNull)

  @@unique([tenantId, branchId, categoryCode, code])
  @@index([tenantId])
  @@index([tenantId, categoryCode])
  @@index([masterItemId])
}

// ─── Master Lookup (legacy, to be replaced) ───────────────────

model MasterLookup {
  id        String  @id @default(cuid())
  tenantId  String
  category  String
  code      String
  name      String
  description String?
  metadata  Json?   @default("{}")
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, category, code])
  @@index([tenantId])
  @@index([category])
}
