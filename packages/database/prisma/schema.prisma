generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  EXPIRED
  CANCELLED
}

enum BranchStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  INVITED
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  MANAGE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  IMPERSONATE
  EXPORT
  IMPORT
  ARCHIVE
  RESTORE
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
  TASK
  REMINDER
  ALERT
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
}

// ─── Platform ─────────────────────────────────────────────────

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  logo      String?
  status    TenantStatus @default(TRIAL)
  settings  Json?        @default("{}")
  metadata  Json?        @default("{}")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  branches        Branch[]
  users           UserTenantMembership[]
  roles           Role[]
  auditLogs       AuditLog[]
  tenantSettings  TenantSetting[]
  documents       Document[]
  activities      Activity[]

  @@index([status])
  @@index([slug])
}

model TenantSetting {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
}

// ─── Branch Management ────────────────────────────────────────

model Branch {
  id        String       @id @default(cuid())
  tenantId  String
  name      String
  code      String
  address   String?
  phone     String?
  email     String?
  status    BranchStatus @default(ACTIVE)
  metadata  Json?        @default("{}")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  tenant      Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       UserBranchMembership[]
  departments Department[]
  activities  Activity[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ─── Department ───────────────────────────────────────────────

model Department {
  id        String   @id @default(cuid())
  branchId  String
  tenantId  String
  name      String
  code      String
  parentId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  branch   Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  parent   Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentHierarchy")
  members  DepartmentMember[]

  @@unique([tenantId, branchId, code])
  @@index([tenantId])
  @@index([branchId])
}

model DepartmentMember {
  userId       String
  departmentId String
  tenantId     String
  isLead       Boolean @default(false)
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([userId, departmentId])
  @@index([tenantId])
}

// ─── User & RBAC ──────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatar       String?
  status       UserStatus @default(ACTIVE)
  isPlatformSuperAdmin Boolean @default(false)
  lastLoginAt  DateTime?
  metadata     Json?      @default("{}")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  tenantMemberships UserTenantMembership[]
  branchMemberships UserBranchMembership[]
  roleAssignments   UserRoleAssignment[]
  departmentMembers DepartmentMember[]
  createdAudits     AuditLog[]          @relation("AuditActor")
  activities        Activity[]          @relation("ActivityCreator")
  documents         Document[]          @relation("DocumentUploader")
  notifications     Notification[]
  leaveApprovals    Leave[]
  authoredReviews   PerformanceReview[]

  @@index([email])
  @@index([status])
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  assignments UserRoleAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id          String   @id @default(cuid())
  module      String
  action      PermissionAction
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@index([module])
}

model RolePermission {
  roleId       String
  permissionId String
  constraints  Json?   @default("{}")
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserTenantMembership {
  userId       String
  tenantId     String
  role         MembershipRole @default(MEMBER)
  isActive     Boolean        @default(true)
  joinedAt     DateTime       @default(now())
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([userId, tenantId])
  @@index([tenantId])
}

model UserBranchMembership {
  userId       String
  branchId     String
  tenantId     String
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  joinedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@index([tenantId])
  @@index([branchId])
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  tenantId  String
  branchId  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, branchId])
  @@index([tenantId])
}

// ─── Audit & Activity ─────────────────────────────────────────

model AuditLog {
  id        String     @id @default(cuid())
  tenantId  String
  branchId  String?
  actorId   String
  action    AuditAction
  module    String
  entity    String
  entityId  String?
  metadata  Json?      @default("{}")
  ipAddress String?
  userAgent String?
  createdAt DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User   @relation("AuditActor", fields: [actorId], references: [id])

  @@index([tenantId])
  @@index([actorId])
  @@index([module])
  @@index([entity, entityId])
  @@index([createdAt])
}

model Activity {
  id        String   @id @default(cuid())
  tenantId  String
  branchId  String?
  userId    String
  type      String
  subject   String
  content   String?
  entity    String?
  entityId  String?
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id])
  user   User    @relation("ActivityCreator", fields: [userId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ─── Notification ─────────────────────────────────────────────

model Notification {
  id        String             @id @default(cuid())
  tenantId  String
  userId    String
  type      NotificationType  @default(INFO)
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String?
  metadata  Json?              @default("{}")
  isRead    Boolean            @default(false)
  readAt    DateTime?
  createdAt DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, isRead])
  @@index([createdAt])
}

// ─── Document ─────────────────────────────────────────────────

model Document {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  uploadedById String?
  category    String
  fileName    String
  storageKey  String
  mimeType    String
  sizeBytes   Int?
  entity      String?
  entityId    String?
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy User?  @relation("DocumentUploader", fields: [uploadedById], references: [id])

  @@index([tenantId])
  @@index([entity, entityId])
  @@index([category])
}

// ─── Master Data ──────────────────────────────────────────────

model Country {
  id        String  @id @default(cuid())
  name      String
  iso2      String  @unique
  iso3      String? @unique
  dialCode  String?
  currencyCode String?
  continent String?
  flagUrl   String?
  nationalityLabel String?
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  airlines     Airline[]      @relation("AirlineCountry")
  airports     Airport[]      @relation("AirportCountry")
  nationalities Nationality[]

  @@index([iso2])
  @@index([continent])
}

model Nationality {
  id        String  @id @default(cuid())
  countryId String
  name      String
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())

  country Country @relation(fields: [countryId], references: [id])

  @@unique([countryId, name])
}

model Currency {
  id           String  @id @default(cuid())
  code         String  @unique
  name         String
  symbol       String
  decimalPlaces Int    @default(2)
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Airline {
  id        String  @id @default(cuid())
  iataCode  String  @unique
  icaoCode  String?
  name      String
  countryId String?
  logoUrl   String?
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  country Country? @relation("AirlineCountry", fields: [countryId], references: [id])

  @@index([iataCode])
}

model Airport {
  id        String  @id @default(cuid())
  iataCode  String  @unique
  icaoCode  String?
  name      String
  city      String
  countryId String?
  timezone  String?
  latitude  Float?
  longitude Float?
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  country Country? @relation("AirportCountry", fields: [countryId], references: [id])

  @@index([iataCode])
  @@index([city])
}

model CabinClass {
  id        String  @id @default(cuid())
  code      String
  name      String
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code])
}

// ─── CRM Foundation ───────────────────────────────────────────

model Lead {
  id        String   @id @default(cuid())
  tenantId  String
  branchId  String?
  status    String   @default("NEW")
  priority  String   @default("MEDIUM")

  // Identity
  fullName     String
  firstName    String?
  lastName     String?
  preferredName String?
  gender       String?
  dateOfBirth  DateTime?
  nationalityId String?
  passportNationalityId String?
  maritalStatus String?
  profession   String?
  companyName  String?
  designation  String?

  // Contact
  primaryMobile    String?
  secondaryMobile  String?
  whatsappNumber   String?
  email            String?
  alternativeEmail String?
  facebookProfile  String?
  instagramHandle  String?
  linkedinProfile  String?
  telegramHandle   String?
  viberHandle      String?

  // Location
  countryId   String?
  city        String?
  areaRegion  String?
  fullAddress String?
  postalCode  String?
  timezoneId  String?

  // Source tracking
  source          String?
  sourcePlatform  String?
  campaignName    String?
  adSet           String?
  referralSource  String?
  referralPerson  String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  landingPage     String?
  importBatchId   String?
  creationMethod  String?

  // Travel requirement
  serviceType          String?
  travelCategory       String?
  isDomestic           Boolean  @default(false)
  tripType             String?
  departureCity        String?
  departureAirportId   String?
  destinationCity      String?
  destinationAirportId String?
  preferredAirlineIds  String?
  transitPreference    String?
  cabinTypeId          String?
  flexibleDates        Boolean  @default(false)
  preferredTravelDate  DateTime?
  returnDate           DateTime?
  alternateDateOptions String?
  numAdults            Int      @default(1)
  numChildren          Int      @default(0)
  numInfants           Int      @default(0)
  passengerNotes       String?

  // Visa
  visaCountryId        String?
  visaTypeText         String?
  travelHistoryNotes   String?
  previousRefusal      Boolean  @default(false)
  urgentVisaProcessing Boolean  @default(false)

  // Tour / Hotel
  hotelPreference      String?
  hotelStarCategory    String?
  mealPreference       String?
  tourType             String?
  destinationInterests String?

  // Communication
  preferredContactMethod String?
  preferredContactTime   String?
  languagePreference     String?

  // Sales pipeline
  leadScore             Int?
  conversionProbability Int?
  potentialRevenue      Decimal  @default(0)
  urgencyLevel          String?
  firstResponseAt       DateTime?
  lastContactAt         DateTime?
  nextFollowUpAt        DateTime?
  followUpCount         Int      @default(0)
  lastFollowUpOutcome   String?
  expectedConversionAt  DateTime?

  // Quotation aggregates
  quoteCount           Int      @default(0)
  lastQuoteId          String?
  lastQuoteStatus      String?
  lastQuoteAmount      Decimal  @default(0)
  selectedQuoteOption  String?
  quoteRevisionCount   Int      @default(0)

  // Booking intent
  confirmedInterest  Boolean @default(false)
  paymentReadiness   String?
  decisionMaker      String?
  approvalPending    Boolean @default(false)

  // Workflow / SLA
  workflowStage     String?
  checklistProgress Int     @default(0)
  slaStatus         String?
  slaDueAt          DateTime?
  slaBreached       Boolean @default(false)
  delayReason       String?
  escalationStatus  String?

  // Financial intelligence
  approxBudget          Decimal  @default(0)
  budgetMin             Decimal  @default(0)
  budgetMax             Decimal  @default(0)
  currencyCode          String?
  paymentPreference     String?
  financingRequirement  String?
  estimatedProfit       Decimal  @default(0)
  estimatedCommission   Decimal  @default(0)
  vipPotential          Boolean  @default(false)
  repeatCustomerPotential Boolean @default(false)

  // AI / smart analytics
  smartPriority              Int?
  leadTemperature            String?
  behavioralPattern          String?
  engagementScore            Int?
  conversionPredictionScore  Int?
  autoAssignmentTriggered    Boolean @default(false)
  autoReminderSent           Boolean @default(false)
  duplicateScore             Int?

  // Corporate / B2B
  isCorporateLead              Boolean @default(false)
  companyType                  String?
  employeeCount                Int?
  travelFrequency              String?
  corporateAgreementPotential  Boolean @default(false)
  agentType                    String?
  agencyName                   String?
  subAgentReference            String?
  commissionCategory           String?

  // Ownership
  clientId      String?
  assignedToId  String?
  ownerId       String?
  teamId        String?
  approvalRequired Boolean @default(false)

  notes       String?
  metadata    Json?       @default("{}")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  @@index([tenantId])
  @@index([branchId])
  @@index([assignedToId])
  @@index([status])
  @@index([tenantId, status])
}

model Client {
  id        String   @id @default(cuid())
  tenantId  String
  branchId  String?

  // Identity
  type      String   @default("PERSON")
  status    String   @default("ACTIVE")
  isVip     Boolean  @default(false)
  displayName String
  surname   String?
  givenNames String?
  email     String?
  phone     String?
  whatsapp  String?
  companyName String?
  companyInfo String?
  profession String?

  // Personal
  dateOfBirth DateTime?
  gender      String?
  nationalityId String?
  nationalityLabel String?
  language    String?
  timezone    String?

  // Preferences
  preferredCommunication String?
  preferredPaymentMethod String?
  preferredAirlines      String?
  preferredRoutes        String?
  loyaltyStatus          String?
  paymentBehavior        String?
  communicationStatus    String?

  // Contact/Emergency
  emergencyPhone   String?
  socialMediaLink  String?
  address          String?
  city             String?
  country          String?
  nationalId       String?

  // Finance/Intelligence
  currencyCode       String   @default("USD")
  riskScore          Int?
  creditLimit        Decimal  @default(0)
  b2bCreditStatus    String?
  outstandingBalance Decimal  @default(0)
  refundAmountTotal  Decimal  @default(0)
  overdueInvoices    Int      @default(0)
  visaHistoryCount   Int      @default(0)
  cancellationCount  Int      @default(0)
  refundFrequency    String?

  // Operational
  ownerId        String?
  branchName     String?
  leadSource     String?
  aiInsights     String?
  alerts         String?
  lastActivityAt DateTime?
  lastBookingAt  DateTime?
  phoneVerified  Boolean  @default(false)
  emailVerified  Boolean  @default(false)
  whatsappAvailable Boolean @default(false)

  notes     String?
  metadata  Json?     @default("{}")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  passports ClientPassport[]
  activities ClientActivity[]
  tasks     ClientTask[]

  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, email])
}

model ClientPassport {
  id             String   @id @default(cuid())
  tenantId       String
  branchId       String?
  clientId       String
  passportNumber String
  fullName       String
  expiryDate     DateTime
  nationality    String?
  countryCode    String?
  status         String   @default("ACTIVE")
  isActive       Boolean  @default(true)
  isVerified     Boolean  @default(false)
  hasMrz         Boolean  @default(false)
  hasOcr         Boolean  @default(false)
  notes          String?
  verifiedById   String?
  verifiedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([clientId])
}

model ClientActivity {
  id        String   @id @default(cuid())
  tenantId  String
  branchId  String?
  clientId  String
  type      String
  message   String?
  metadata  Json?    @default("{}")
  createdById String?
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([clientId])
  @@index([type])
}

model ClientTask {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  clientId    String
  priority    String   @default("MEDIUM")
  status      String   @default("PENDING")
  title       String
  description String?
  assignedToId String?
  dueDate     DateTime?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([clientId])
  @@index([assignedToId])
  @@index([status])
}

model FollowUp {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  leadId      String?
  clientId    String?
  assignedToId String?
  channel     String   @default("PHONE")
  subject     String
  description String?
  scheduledAt DateTime
  completedAt DateTime?
  status      String   @default("PENDING")
  outcome     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([assignedToId])
  @@index([status])
  @@index([scheduledAt])
}

// ─── Quotation / Booking / Ticketing ──────────────────────────

model Quotation {
  id              String   @id @default(cuid())
  tenantId        String
  branchId        String?
  quoteNumber     String
  status          String   @default("DRAFT")
  title           String?
  clientId        String?
  leadId          String?
  assignedToId    String?
  currencyCode    String   @default("USD")

  // Computed totals (fed from line items)
  subtotal        Decimal  @default(0)
  taxTotal        Decimal  @default(0)
  discountTotal   Decimal  @default(0)
  grandTotal      Decimal  @default(0)

  validUntil      DateTime?
  notes           String?
  terms           String?

  // Visibility / source
  visibilityScope   String?
  assignedBranchId  String?
  sourceBranchId    String?
  billingBranchId   String?
  sourceContextType String?
  sourceContextId   String?
  sourceContextRef  String?

  // Revision tracking
  currentRevision   Int     @default(1)

  // Status timestamps
  sentAt          DateTime?
  viewedAt        DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  expiredAt       DateTime?
  cancelledAt     DateTime?
  bookingCreatedAt DateTime?
  pnrCreatedAt    DateTime?
  paymentPendingAt DateTime?
  paymentReceivedAt DateTime?
  ticketIssuedAt  DateTime?
  completedAt     DateTime?
  archivedAt      DateTime?

  createdById  String?
  updatedById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  lineItems  QuotationLineItem[]
  revisions  QuotationRevision[]
  statusLogs QuotationStatusLog[]

  @@unique([tenantId, quoteNumber])
  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, status])
}

model QuotationLineItem {
  id          String   @id @default(cuid())
  tenantId    String
  quotationId String
  serviceType String?
  title       String?
  description String?
  quantity    Int      @default(1)
  unitPrice   Decimal  @default(0)
  lineTotal   Decimal  @default(0)
  airlineId   String?
  originAirportId String?
  destAirportId   String?
  routeId     String?
  metadata    Json?    @default("{}")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([quotationId])
}

model QuotationRevision {
  id             String   @id @default(cuid())
  tenantId       String
  quotationId    String
  revisionNumber Int
  summary        String?
  snapshot       Json
  pdfAssetKey    String?
  createdById    String?
  createdAt      DateTime @default(now())

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([quotationId])
}

model QuotationStatusLog {
  id          String   @id @default(cuid())
  tenantId    String
  quotationId String
  fromStatus  String?
  toStatus    String
  note        String?
  metadata    Json?    @default("{}")
  actorId     String?
  createdAt   DateTime @default(now())

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([quotationId])
}

model Booking {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  bookingRef  String
  pnrLocator  String?
  status      String   @default("HELD")
  clientId    String?
  quotationId String?
  leadId      String?
  assignedToId String?
  travelStart DateTime?
  travelEnd   DateTime?
  holdExpiresAt DateTime?
  notes       String?
  createdById  String?
  updatedById  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@unique([tenantId, bookingRef])
  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, status])
}

model Ticket {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  bookingId   String
  ticketNumber String
  passengerName String?
  passengerId  String?
  airlineId   String?
  status      String   @default("PENDING")
  issuedAt    DateTime?
  voidedAt    DateTime?
  refundedAt  DateTime?
  reissuedAt  DateTime?
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, ticketNumber])
  @@index([tenantId])
  @@index([bookingId])
}

// ─── Finance Foundation ───────────────────────────────────────

model Invoice {
  id            String   @id @default(cuid())
  tenantId      String
  branchId      String?
  invoiceNumber String
  clientId      String?
  bookingId     String?
  currencyCode  String   @default("USD")
  subtotal      Decimal  @default(0)
  taxAmount     Decimal  @default(0)
  discountAmount Decimal @default(0)
  totalAmount   Decimal  @default(0)
  paidAmount    Decimal  @default(0)
  dueAmount     Decimal  @default(0)
  status        String   @default("DRAFT")
  issuedAt      DateTime?
  dueAt         DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([branchId])
  @@index([tenantId, status])
}

model Receipt {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  receiptNumber String
  invoiceId   String?
  paymentMethod String?
  amount      Decimal  @default(0)
  currencyCode String  @default("USD")
  reference   String?
  notes       String?
  receivedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, receiptNumber])
  @@index([tenantId])
  @@index([invoiceId])
}

model Payment {
  id             String   @id @default(cuid())
  tenantId       String
  branchId       String?
  bookingId      String?
  invoiceId      String?
  amount         Decimal  @default(0)
  currencyCode   String   @default("USD")
  paymentMethod  String?
  status         String   @default("PENDING")
  reference      String?
  idempotencyKey  String?
  notes          String?
  receivedAt     DateTime?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([bookingId])
  @@index([invoiceId])
}

model Expense {
  id            String   @id @default(cuid())
  tenantId      String
  branchId      String?
  expenseNumber String
  category      String?
  vendorName    String?
  currencyCode  String   @default("USD")
  amount        Decimal  @default(0)
  status        String   @default("PENDING")
  description   String?
  expenseDate   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@unique([tenantId, expenseNumber])
  @@index([tenantId])
  @@index([branchId])
}

model LedgerEntry {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  entryDate   DateTime @default(now())
  referenceType String?
  referenceId String?
  direction   String
  currencyCode String  @default("USD")
  amount      Decimal  @default(0)
  description String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([referenceType, referenceId])
}

// ─── HRM Foundation ───────────────────────────────────────────

model Employee {
  id           String   @id @default(cuid())
  tenantId     String
  branchId     String?
  employeeCode String
  userId       String?  @unique
  departmentId String?
  firstName    String
  lastName     String
  email        String?
  phone        String?
  position     String?
  status       String   @default("ACTIVE")
  joinedAt     DateTime?
  metadata     Json?    @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  leaves       Leave[]
  attendances  Attendance[]
  reviews      PerformanceReview[]

  @@unique([tenantId, employeeCode])
  @@index([tenantId])
  @@index([branchId])
  @@index([departmentId])
}

model Leave {
  id          String   @id @default(cuid())
  tenantId    String
  employeeId  String
  leaveType   String
  startDate   DateTime
  endDate     DateTime
  status      String   @default("PENDING")
  reason      String?
  approvedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([employeeId])
  @@index([status])

  employee   Employee @relation(fields: [employeeId], references: [id])
  approvedBy User?    @relation(fields: [approvedById], references: [id])
}

model Attendance {
  id         String   @id @default(cuid())
  tenantId   String
  employeeId String
  date       DateTime
  clockIn    DateTime?
  clockOut   DateTime?
  status     String   @default("PRESENT")
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, employeeId, date])
  @@index([tenantId])

  employee Employee @relation(fields: [employeeId], references: [id])
}

model PerformanceReview {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  reviewerId    String?
  period        String
  rating        Int?
  strengths     String?
  improvements  String?
  notes         String?
  status        String   @default("DRAFT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([employeeId])

  employee Employee @relation(fields: [employeeId], references: [id])
  reviewer User?    @relation(fields: [reviewerId], references: [id])
}

// ─── Master Lookup ────────────────────────────────────────────

model MasterLookup {
  id        String  @id @default(cuid())
  tenantId  String
  category  String
  code      String
  name      String
  description String?
  metadata  Json?   @default("{}")
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, category, code])
  @@index([tenantId])
  @@index([category])
}
