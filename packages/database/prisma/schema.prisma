generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  EXPIRED
  CANCELLED
}

enum BranchStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  INVITED
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  MANAGE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  IMPERSONATE
  EXPORT
  IMPORT
  ARCHIVE
  RESTORE
  STATUS_CHANGE
  APPROVE
  REJECT
  REFUND
  VOID
  REISSUE
  CANCEL
  ISSUE
  PAY
  REQUEST
  PROCESS
  CONVERT
  ASSIGN
  DOWNLOAD
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
  TASK
  REMINDER
  ALERT
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
}

// ─── Platform ─────────────────────────────────────────────────

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  logo      String?
  status    TenantStatus @default(TRIAL)
  trialEndsAt   DateTime?
  maxUsers      Int       @default(5)
  maxBranches   Int       @default(1)
  settings  Json?        @default("{}")
  metadata  Json?        @default("{}")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  branches        Branch[]
  users           UserTenantMembership[]
  roles           Role[]
  auditLogs       AuditLog[]
  tenantSettings  TenantSetting[]
  documents       Document[]
  activities      Activity[]
  masterDataOverrides TenantMasterDataOverride[]
  leads           Lead[]
  clients         Client[]
  followUps       FollowUp[]
  quotations      Quotation[]
  bookings        Booking[]
  tickets         Ticket[]
  invoices        Invoice[]
  receipts        Receipt[]
  payments        Payment[]
  expenses        Expense[]
  ledgerEntries   LedgerEntry[]
  employees       Employee[]
  leaves          Leave[]
  attendances     Attendance[]
  performanceReviews PerformanceReview[]
  refunds     RefundRequest[]
  reissues    ReissueRequest[]
  cancellations CancellationRequest[]
  insurances      Insurance[]
  bankAccounts    BankAccount[]
  cashRegisters   CashRegister[]
  transactionLogs TransactionLog[]

  salaryProfiles  SalaryProfile[]
  salaryRuns      SalaryRun[]
  salarySlips     SalarySlip[]
  commissions     Commission[]
  incentives      Incentive[]
  subscription    TenantSubscription?
  projects        Project[]
  vendors         Vendor[]
  knowledgeArticles KnowledgeArticle[]

  @@index([status])
  @@index([slug])
}

model Package {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  description   String?
  priceMonthly  Decimal  @db.Decimal(10, 2) @default(0)
  priceYearly   Decimal  @db.Decimal(10, 2) @default(0)
  maxUsers      Int      @default(5)
  maxBranches   Int      @default(1)
  features      Json?    @default("{}")
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions TenantSubscription[]
}

model TenantSubscription {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  packageId       String
  status          String   @default("ACTIVE")
  startedAt       DateTime @default(now())
  endsAt          DateTime?
  trialEndsAt     DateTime?
  cancelledAt     DateTime?
  renewedAt       DateTime?
  billingCycle    String   @default("MONTHLY")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  package Package @relation(fields: [packageId], references: [id])
}

model TenantSetting {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
}

// ─── Branch Management ────────────────────────────────────────

model Branch {
  id        String       @id @default(cuid())
  tenantId  String
  name      String
  code      String
  address   String?
  phone     String?
  email     String?
  status    BranchStatus @default(ACTIVE)
  metadata  Json?        @default("{}")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  tenant      Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       UserBranchMembership[]
  departments Department[]
  activities  Activity[]
  masterDataOverrides TenantMasterDataOverride[]
  leads       Lead[]
  clients     Client[]
  followUps   FollowUp[]
  quotations  Quotation[]
  bookings    Booking[]
  tickets     Ticket[]
  invoices    Invoice[]
  receipts    Receipt[]
  payments    Payment[]
  expenses    Expense[]
  employees   Employee[]
  refunds     RefundRequest[]
  reissues    ReissueRequest[]
  cancellations CancellationRequest[]
  salaryRuns  SalaryRun[]
  commissions Commission[]
  incentives  Incentive[]
  ledgerEntries LedgerEntry[]
  projects      Project[]
  vendors       Vendor[]
  insurances    Insurance[]
  bankAccounts  BankAccount[]
  cashRegisters CashRegister[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ─── Department ───────────────────────────────────────────────

model Department {
  id        String   @id @default(cuid())
  branchId  String
  tenantId  String
  name      String
  code      String
  parentId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  branch   Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  parent   Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentHierarchy")
  members  DepartmentMember[]
  employees Employee[]

  @@unique([tenantId, branchId, code])
  @@index([tenantId])
  @@index([branchId])
}

model DepartmentMember {
  userId       String
  departmentId String
  tenantId     String
  isLead       Boolean @default(false)
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([userId, departmentId])
  @@index([tenantId])
}

// ─── User & RBAC ──────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatar       String?
  status       UserStatus @default(ACTIVE)
  isPlatformSuperAdmin Boolean @default(false)
  lastLoginAt  DateTime?
  failedLoginAttempts Int    @default(0)
  lockedUntil  DateTime?
  metadata     Json?      @default("{}")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  tenantMemberships UserTenantMembership[]
  branchMemberships UserBranchMembership[]
  roleAssignments   UserRoleAssignment[]
  departmentMembers DepartmentMember[]
  createdAudits     AuditLog[]          @relation("AuditActor")
  activities        Activity[]          @relation("ActivityCreator")
  documents         Document[]          @relation("DocumentUploader")
  notifications     Notification[]
  leaveApprovals    Leave[]
  authoredReviews   PerformanceReview[]
  refreshTokens     RefreshToken[]
  loginHistory      LoginHistory[]
  securityEvents    SecurityEvent[]
  assignedLeads     Lead[]              @relation("LeadAssignee")
  ownedLeads        Lead[]              @relation("LeadOwner")
  ownedClients      Client[]            @relation("ClientOwner")
  assignedFollowUps FollowUp[]          @relation("FollowUpAssignee")
  assignedQuotations Quotation[]        @relation("QuotationAssignee")
  assignedBookings  Booking[]           @relation("BookingAssignee")
  assignedCases     Case[]              @relation("CaseAssignee")
  receivedPayments  Payment[]           @relation("PaymentReceiver")
  employeeRecord    Employee?           @relation("EmployeeUser")
  refundRequested   RefundRequest[]     @relation("RefundRequester")
  refundApproved    RefundRequest[]     @relation("RefundApprover")
  refundProcessed   RefundRequest[]     @relation("RefundProcessor")
  reissueRequested  ReissueRequest[]    @relation("ReissueRequester")
  reissueApproved   ReissueRequest[]    @relation("ReissueApprover")
  reissueProcessed  ReissueRequest[]    @relation("ReissueProcessor")
  cancelRequested   CancellationRequest[] @relation("CancelRequester")
  cancelApproved    CancellationRequest[] @relation("CancelApprover")
  cancelProcessed   CancellationRequest[] @relation("CancelProcessor")
  commissionApproved Commission[]       @relation("CommissionApprover")
  incentiveApproved  Incentive[]        @relation("IncentiveApprover")
  createdRefunds     RefundRequest[]    @relation("RefundCreator")
  createdReissues    ReissueRequest[]   @relation("ReissueCreator")
  createdCancellations CancellationRequest[] @relation("CancelCreator")
  createdCommissions Commission[]       @relation("CommissionCreator")
  createdIncentives  Incentive[]        @relation("IncentiveCreator")
  createdSalaryProfiles SalaryProfile[] @relation("SalaryProfileCreator")
  createdSalaryRuns  SalaryRun[]        @relation("SalaryRunCreator")
  approvedSalaryRuns SalaryRun[]        @relation("SalaryRunApprover")
  managedProjects    Project[]          @relation("ProjectManager")
  projectMembers   ProjectMember[]
  assignedTasks      Task[]             @relation("TaskAssignee")
  completedChecklists TaskChecklist[]   @relation("ChecklistCompleter")
  projectTimeLogs    ProjectTimeLog[]  @relation("TimeLogUser")
  knowledgeArticles  KnowledgeArticle[] @relation("KnowledgeAuthor")

  @@index([email])
  @@index([status])
}

// ─── Auth / Security ──────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  device    String?
  ip        String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  email     String
  ip        String?
  userAgent String?
  success   Boolean  @default(true)
  failReason String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([createdAt])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  userId    String
  type      String
  details   String?
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  assignments UserRoleAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id          String   @id @default(cuid())
  module      String
  action      PermissionAction
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@index([module])
}

model RolePermission {
  roleId       String
  permissionId String
  constraints  Json?   @default("{}")
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserTenantMembership {
  userId       String
  tenantId     String
  role         MembershipRole @default(MEMBER)
  isActive     Boolean        @default(true)
  joinedAt     DateTime       @default(now())
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([userId, tenantId])
  @@index([tenantId])
}

model UserBranchMembership {
  userId       String
  branchId     String
  tenantId     String
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  joinedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@index([tenantId])
  @@index([branchId])
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  tenantId  String
  branchId  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, branchId])
  @@index([tenantId])
}

// ─── Audit & Activity ─────────────────────────────────────────

model AuditLog {
  id        String     @id @default(cuid())
  tenantId  String
  branchId  String?
  actorId   String
  action    AuditAction
  module    String
  entity    String
  entityId  String?
  metadata  Json?      @default("{}")
  ipAddress String?
  userAgent String?
  createdAt DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User   @relation("AuditActor", fields: [actorId], references: [id])

  @@index([tenantId])
  @@index([actorId])
  @@index([module])
  @@index([entity, entityId])
  @@index([createdAt])
}

model Activity {
  id        String   @id @default(cuid())
  tenantId  String
  branchId  String?
  userId    String
  type      String
  subject   String
  content   String?
  entity    String?
  entityId  String?
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now())

  tenant Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch?  @relation(fields: [branchId], references: [id])
  user   User    @relation("ActivityCreator", fields: [userId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ─── Notification ─────────────────────────────────────────────

model Notification {
  id        String             @id @default(cuid())
  tenantId  String
  userId    String
  type      NotificationType  @default(INFO)
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String?
  metadata  Json?              @default("{}")
  isRead    Boolean            @default(false)
  readAt    DateTime?
  createdAt DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, isRead])
  @@index([createdAt])
}

// ─── Document ─────────────────────────────────────────────────

model Document {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  uploadedById String?
  category    String
  fileName    String
  storageKey  String
  mimeType    String
  sizeBytes   Int?
  entity      String?
  entityId    String?
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy User?  @relation("DocumentUploader", fields: [uploadedById], references: [id])

  @@index([tenantId])
  @@index([entity, entityId])
  @@index([category])
}

// ─── Master Data ──────────────────────────────────────────────

model Country {
  id        String  @id @default(cuid())
  name      String
  iso2      String  @unique
  iso3      String? @unique
  dialCode  String?
  currencyCode String?
  continent String?
  flagUrl   String?
  nationalityLabel String?
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  airlines     Airline[]      @relation("AirlineCountry")
  airports     Airport[]      @relation("AirportCountry")
  nationalities Nationality[]
  visas         ClientVisa[]

  @@index([iso2])
  @@index([continent])
}

model Nationality {
  id        String  @id @default(cuid())
  countryId String
  name      String
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())

  country Country @relation(fields: [countryId], references: [id])

  @@unique([countryId, name])
}

model Currency {
  id           String  @id @default(cuid())
  code         String  @unique
  name         String
  symbol       String
  decimalPlaces Int    @default(2)
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Airline {
  id        String  @id @default(cuid())
  iataCode  String  @unique
  icaoCode  String?
  name      String
  countryId String?
  logoUrl   String?
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  country Country? @relation("AirlineCountry", fields: [countryId], references: [id])
  tickets Ticket[]

  @@index([iataCode])
}

model Airport {
  id        String  @id @default(cuid())
  iataCode  String  @unique
  icaoCode  String?
  name      String
  city      String
  countryId String?
  timezone  String?
  latitude  Float?
  longitude Float?
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  country Country? @relation("AirportCountry", fields: [countryId], references: [id])
  terminals AirportTerminal[]

  @@index([iataCode])
  @@index([city])
}

model CabinClass {
  id        String  @id @default(cuid())
  code      String
  name      String
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code])
}

model Timezone {
  id        String  @id @default(cuid())
  code      String  @unique
  name      String
  city      String?
  iataCode  String?
  countryCode String?
  utcOffset String
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([city])
}

// ─── Aviation Reference ───────────────────────────────────────

model AircraftType {
  id        String  @id @default(cuid())
  iataCode  String  @unique
  name      String
  category  String? // e.g. Jet, Turboprop, Regional
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([iataCode])
  @@index([category])
}

model AirlineAlliance {
  id        String  @id @default(cuid())
  code      String  @unique
  name      String
  description String?
  website   String?
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
}

model AirportTerminal {
  id        String  @id @default(cuid())
  airportId String
  code      String
  name      String
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  airport Airport @relation(fields: [airportId], references: [id], onDelete: Cascade)

  @@unique([airportId, code])
  @@index([airportId])
}

// ─── CRM Foundation ───────────────────────────────────────────

model Lead {
  id        String   @id @default(cuid())
  tenantId  String
  branchId  String?
  status    String   @default("NEW")
  priority  String   @default("MEDIUM")

  // Identity
  fullName     String
  firstName    String?
  lastName     String?
  preferredName String?
  gender       String?
  dateOfBirth  DateTime?
  nationalityId String?
  passportNationalityId String?
  maritalStatus String?
  profession   String?
  companyName  String?
  designation  String?

  // Contact
  primaryMobile    String?
  secondaryMobile  String?
  whatsappNumber   String?
  email            String?
  alternativeEmail String?
  facebookProfile  String?
  instagramHandle  String?
  linkedinProfile  String?
  telegramHandle   String?
  viberHandle      String?

  // Location
  countryId   String?
  city        String?
  areaRegion  String?
  fullAddress String?
  postalCode  String?
  timezoneId  String?

  // Source tracking
  source          String?
  sourcePlatform  String?
  campaignName    String?
  adSet           String?
  referralSource  String?
  referralPerson  String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  landingPage     String?
  importBatchId   String?
  creationMethod  String?

  // Travel requirement
  serviceType          String?
  travelCategory       String?
  isDomestic           Boolean  @default(false)
  tripType             String?
  departureCity        String?
  departureAirportId   String?
  destinationCity      String?
  destinationAirportId String?
  preferredAirlineIds  String?
  transitPreference    String?
  cabinTypeId          String?
  flexibleDates        Boolean  @default(false)
  preferredTravelDate  DateTime?
  returnDate           DateTime?
  alternateDateOptions String?
  numAdults            Int      @default(1)
  numChildren          Int      @default(0)
  numInfants           Int      @default(0)
  passengerNotes       String?

  // Visa
  visaCountryId        String?
  visaTypeText         String?
  travelHistoryNotes   String?
  previousRefusal      Boolean  @default(false)
  urgentVisaProcessing Boolean  @default(false)

  // Tour / Hotel
  hotelPreference      String?
  hotelStarCategory    String?
  mealPreference       String?
  tourType             String?
  destinationInterests String?

  // Communication
  preferredContactMethod String?
  preferredContactTime   String?
  languagePreference     String?

  // Sales pipeline
  leadScore             Int?
  conversionProbability Int?
  potentialRevenue      Decimal @db.Decimal(19, 4)  @default(0)
  urgencyLevel          String?
  firstResponseAt       DateTime?
  lastContactAt         DateTime?
  nextFollowUpAt        DateTime?
  followUpCount         Int      @default(0)
  lastFollowUpOutcome   String?
  expectedConversionAt  DateTime?

  // Quotation aggregates
  quoteCount           Int      @default(0)
  lastQuoteId          String?
  lastQuoteStatus      String?
  lastQuoteAmount      Decimal @db.Decimal(19, 4)  @default(0)
  selectedQuoteOption  String?
  quoteRevisionCount   Int      @default(0)

  // Booking intent
  confirmedInterest  Boolean @default(false)
  paymentReadiness   String?
  decisionMaker      String?
  approvalPending    Boolean @default(false)

  // Workflow / SLA
  workflowStage     String?
  checklistProgress Int     @default(0)
  slaStatus         String?
  slaDueAt          DateTime?
  slaBreached       Boolean @default(false)
  delayReason       String?
  escalationStatus  String?

  // Financial intelligence
  approxBudget          Decimal @db.Decimal(19, 4)  @default(0)
  budgetMin             Decimal @db.Decimal(19, 4)  @default(0)
  budgetMax             Decimal @db.Decimal(19, 4)  @default(0)
  currencyCode          String?
  paymentPreference     String?
  financingRequirement  String?
  estimatedProfit       Decimal @db.Decimal(19, 4)  @default(0)
  estimatedCommission   Decimal @db.Decimal(19, 4)  @default(0)
  vipPotential          Boolean  @default(false)
  repeatCustomerPotential Boolean @default(false)

  // AI / smart analytics
  smartPriority              Int?
  leadTemperature            String?
  behavioralPattern          String?
  engagementScore            Int?
  conversionPredictionScore  Int?
  autoAssignmentTriggered    Boolean @default(false)
  autoReminderSent           Boolean @default(false)
  duplicateScore             Int?

  // Corporate / B2B
  isCorporateLead              Boolean @default(false)
  companyType                  String?
  employeeCount                Int?
  travelFrequency              String?
  corporateAgreementPotential  Boolean @default(false)
  agentType                    String?
  agencyName                   String?
  subAgentReference            String?
  commissionCategory           String?

  // Ownership
  clientId      String?
  assignedToId  String?
  ownerId       String?
  teamId        String?
  approvalRequired Boolean @default(false)
