  currencyCode    String   @default("USD")

  // Computed totals (fed from line items)
  subtotal        Decimal @db.Decimal(19, 4)  @default(0)
  taxTotal        Decimal @db.Decimal(19, 4)  @default(0)
  discountTotal   Decimal @db.Decimal(19, 4)  @default(0)
  grandTotal      Decimal @db.Decimal(19, 4)  @default(0)

  validUntil      DateTime?
  notes           String?
  terms           String?

  // Visibility / source
  visibilityScope   String?
  assignedBranchId  String?
