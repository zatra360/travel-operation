// ================================================================
// ACCOUNTING FOUNDATION (Audit-First Phase 1)
// Hardened double-entry ledger, fiscal periods, chart of accounts,
// gapless numbering, idempotency, exchange rates, hash-chained audit
// ledger. Posting/reversal happen ONLY through database functions
// (fn_post_journal_entry / fn_reverse_journal_entry); immutability
// is enforced by triggers created in the accounting_foundation
// migration. See docs/prompts/audit-first-erp-prompt.md.
// ================================================================

enum FiscalYearStatus {
  OPEN
  CLOSED
  LOCKED
}

enum PeriodStatus {
  OPEN
  SOFT_CLOSED
  CLOSED
  LOCKED
}

enum GLAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  COGS
  EXPENSE
  OTHER_INCOME
  OTHER_EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum JournalStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  POSTED
  REVERSED
}

enum DocNumberStatus {
  ISSUED
  VOIDED
}

enum IdempotencyStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

model FiscalYear {
  id        String           @id @default(cuid())
  tenantId  String
  code      String
  startDate DateTime
  endDate   DateTime
  status    FiscalYearStatus @default(OPEN)
  createdById String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  periods AccountingPeriod[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model AccountingPeriod {
  id            String       @id @default(cuid())
  tenantId      String
  fiscalYearId  String
  periodNumber  Int
  code          String
  startDate     DateTime
  endDate       DateTime
  status        PeriodStatus @default(OPEN)
  closedById    String?
  closedAt      DateTime?
  reopenedById  String?
  reopenedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  fiscalYear FiscalYear       @relation(fields: [fiscalYearId], references: [id])
  closeLogs  PeriodCloseLog[]
  journals   JournalEntry[]

  @@unique([tenantId, fiscalYearId, periodNumber])
  @@unique([tenantId, code])
  @@index([tenantId, startDate, endDate])
}

model PeriodCloseLog {
  id           String   @id @default(cuid())
  tenantId     String
  periodId     String
  action       String
  reason       String?
  actorId      String
  approvedById String?
  createdAt    DateTime @default(now())

  period AccountingPeriod @relation(fields: [periodId], references: [id])

  @@index([tenantId])
  @@index([periodId])
}

model GLAccount {
  id                 String        @id @default(cuid())
  tenantId           String
  accountCode        String
  accountName        String
  accountType        GLAccountType
  normalBalance      NormalBalance
  parentAccountId    String?
  controlAccountType String?
  currencyCode       String?
  allowManualPosting Boolean       @default(true)
  isActive           Boolean       @default(true)
  effectiveFrom      DateTime?
  effectiveTo        DateTime?
  description        String?
  createdById        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  parent   GLAccount?    @relation("GLAccountHierarchy", fields: [parentAccountId], references: [id])
  children GLAccount[]   @relation("GLAccountHierarchy")
  items    JournalItem[]

  @@unique([tenantId, accountCode])
  @@index([tenantId, accountType])
  @@index([tenantId, isActive])
}

model JournalEntry {
  id                       String        @id @default(cuid())
  tenantId                 String
  branchId                 String?
  journalNumber            String?
  journalType              String        @default("GENERAL")
  entryDate                DateTime
  accountingPeriodId       String?
  currencyCode             String        @default("USD")
  exchangeRate             Decimal       @default(1) @db.Decimal(19, 8)
  functionalCurrencyCode   String        @default("USD")
  sourceType               String?
  sourceId                 String?
  sourceNumber             String?
  description              String?
  status                   JournalStatus @default(DRAFT)
  reversalOfJournalEntryId String?       @unique
  reversedByJournalEntryId String?       @unique
  idempotencyKey           String?
  createdById              String?
  approvedById             String?
  postedById               String?
  reversalReason           String?
  createdAt                DateTime      @default(now())
  approvedAt               DateTime?
  postedAt                 DateTime?
  updatedAt                DateTime      @updatedAt

  accountingPeriod AccountingPeriod?  @relation(fields: [accountingPeriodId], references: [id])
  reversalOf       JournalEntry?      @relation("JournalReversal", fields: [reversalOfJournalEntryId], references: [id])
  reversedByEntry  JournalEntry?      @relation("JournalReversal")
  items            JournalItem[]
  links            JournalEntryLink[]

  @@unique([tenantId, journalNumber])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, status])
  @@index([tenantId, entryDate])
  @@index([tenantId, sourceType, sourceId])
}

model JournalItem {
  id                  String   @id @default(cuid())
  journalEntryId      String
  tenantId            String
  lineNumber          Int
  accountId           String
  partyType           String?
  partyId             String?
  itemId              String?
  warehouseId         String?
  costCenter          String?
  projectId           String?
  description         String?
  debit               Decimal  @default(0) @db.Decimal(19, 4)
  credit              Decimal  @default(0) @db.Decimal(19, 4)
  transactionCurrency String   @default("USD")
  transactionAmount   Decimal  @default(0) @db.Decimal(19, 4)
  exchangeRate        Decimal  @default(1) @db.Decimal(19, 8)
  functionalDebit     Decimal  @default(0) @db.Decimal(19, 4)
  functionalCredit    Decimal  @default(0) @db.Decimal(19, 4)
  taxCodeId           String?
  createdAt           DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      GLAccount    @relation(fields: [accountId], references: [id])

  @@unique([journalEntryId, lineNumber])
  @@index([tenantId, accountId])
  @@index([journalEntryId])
}

model JournalEntryLink {
  id             String   @id @default(cuid())
  tenantId       String
  journalEntryId String
  sourceType     String
  sourceId       String
  purpose        String   @default("PRIMARY")
  createdAt      DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id])

  @@unique([tenantId, sourceType, sourceId, purpose])
  @@index([journalEntryId])
}

model DocumentNumberCounter {
  id             String   @id @default(cuid())
  tenantId       String
  documentType   String
  fiscalYearCode String
  series         String   @default("DEFAULT")
  prefix         String
  nextNumber     Int      @default(1)
  padding        Int      @default(6)
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@unique([tenantId, documentType, fiscalYearCode, series])
}

model DocumentNumberHistory {
  id             String          @id @default(cuid())
  tenantId       String
  documentType   String
  fiscalYearCode String
  series         String          @default("DEFAULT")
  documentNumber String
  recordType     String?
  recordId       String?
  status         DocNumberStatus @default(ISSUED)
  voidReason     String?
  voidedById     String?
  voidedAt       DateTime?
  issuedById     String?
  issuedAt       DateTime        @default(now())

  @@unique([tenantId, documentType, documentNumber])
  @@index([tenantId, documentType, fiscalYearCode])
}

model IdempotencyRecord {
  id             String            @id @default(cuid())
  tenantId       String
  endpoint       String
  idempotencyKey String
  payloadHash    String
  status         IdempotencyStatus @default(IN_PROGRESS)
  responseBody   Json?
  recordType     String?
  recordId       String?
  createdById    String?
  createdAt      DateTime          @default(now())
  completedAt    DateTime?

  @@unique([tenantId, endpoint, idempotencyKey])
  @@index([tenantId, createdAt])
}

model GLExchangeRate {
  id            String   @id @default(cuid())
  tenantId      String
  baseCurrency  String
  quoteCurrency String
  rate          Decimal  @db.Decimal(19, 8)
  rateDate      DateTime
  source        String   @default("MANUAL")
  createdById   String?
  createdAt     DateTime @default(now())

  @@unique([tenantId, baseCurrency, quoteCurrency, rateDate, source])
  @@index([tenantId, baseCurrency, quoteCurrency, rateDate])
}

model SystemAuditLog {
  id                 String   @id @default(cuid())
  tenantId           String
  branchId           String?
  eventSequence      BigInt
  userId             String?
  sessionId          String?
  requestId          String?
  correlationId      String?
  idempotencyKey     String?
  ipAddress          String?
  userAgent          String?
  action             String
  actionCategory     String
  tableName          String?
  recordId           String?
  sourceDocumentType String?
  sourceDocumentId   String?
  beforeState        Json?
  afterState         Json?
  changedFields      Json?
  reason             String?
  approvalReference  String?
  createdAt          DateTime @default(now())
  previousHash       String
  recordHash         String

  @@unique([tenantId, eventSequence])
  @@index([tenantId, action])
  @@index([tenantId, tableName, recordId])
  @@index([tenantId, createdAt])
}

model FinancialRiskAlert {
  id             String    @id @default(cuid())
  tenantId       String
  alertType      String
  severity       String    @default("MEDIUM")
  entityType     String?
  entityId       String?
  dedupeKey      String
  title          String
  description    String?
  metadata       Json?     @default("{}")
  status         String    @default("OPEN")
  reviewedById   String?
  reviewedAt     DateTime?
  resolutionNote String?
  detectedAt     DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([tenantId, dedupeKey])
  @@index([tenantId, status])
  @@index([tenantId, alertType])
}
