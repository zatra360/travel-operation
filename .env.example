# Travel Operation — root environment reference
# Copy per-app examples to real env files before running:
#   apps/api/.env.example -> apps/api/.env
#   apps/web/.env.example -> apps/web/.env
# This root file documents the full set for local development.

# ---- API (apps/api) ----
NODE_ENV=development
PORT=3900
DATABASE_URL=postgresql://travel_operation:travel_operation_dev@localhost:5433/travel_operation?schema=public
WEB_ORIGIN=http://localhost:3901
CORS_ORIGINS=http://localhost:3901
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=24h
REDIS_URL=redis://localhost:6379

# Super admin seed
SUPER_ADMIN_EMAIL=admin@travelo.com
SUPER_ADMIN_PASSWORD=change-me-in-production

# Cloudflare R2 (private storage; MinIO for local dev)
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=travel-operation-dev
R2_PUBLIC_URL=

# ---- Web (apps/web) ----
NEXT_PUBLIC_API_URL=http://localhost:3900
NEXT_PUBLIC_APP_NAME=Travel Operation
